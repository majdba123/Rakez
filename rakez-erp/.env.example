APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
# Run CSV imports in the HTTP request (default true). Set false + queue worker for huge files.
CSV_IMPORT_DISPATCH_SYNC=true

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# predis works without PHP ext-redis; use phpredis + apt install php8.x-redis for lower latency
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Twilio (AI Voice + optional Sales Unit Search Alert SMS) — https://console.twilio.com
# Put real values in .env only; never commit real TWILIO_AUTH_TOKEN.
# SMS alerts reuse TWILIO_ACCOUNT_SID and TWILIO_AUTH_TOKEN.
# SALES_UNIT_SEARCH_ALERT_FROM is optional and falls back to TWILIO_PHONE_NUMBER when omitted.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# TWILIO_WEBHOOK_BASE_URL="${APP_URL}"
# AI_CALLING_ENABLED=false
# TWILIO_REAL_TESTS=false

# Sales Unit Search Alerts
SALES_UNIT_SEARCH_ALERTS_ENABLED=true
SALES_UNIT_SEARCH_ALERT_SMS_ENABLED=false
SALES_UNIT_SEARCH_ALERT_FROM=
SALES_UNIT_SEARCH_ALERT_QUEUE=default
SALES_UNIT_SEARCH_ALERT_DEFAULT_EXPIRATION_DAYS=30
SALES_UNIT_SEARCH_ALERT_CLOSE_AFTER_FIRST_MATCH=true
SALES_UNIT_SEARCH_ALERT_THROTTLE_MINUTES=60
SALES_UNIT_SEARCH_ALERT_DELIVERY_STATUS_CALLBACK_ENABLED=false

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Optional: real OpenAI for AI assistant and AI-call lead qualification integration tests
# OPENAI_API_KEY=
# AI_REAL_TESTS=false

# ========== Ads platforms (Meta, Snap, TikTok) ==========
# All insights/campaign data is synced 100% from platform APIs. See config/ads_platforms.php.

# --- Meta (Facebook PHP Business SDK) ---
# Required for SDK: META_APP_ID, META_APP_SECRET. Get from https://developers.facebook.com
META_APP_ID=
META_APP_SECRET=
META_ADS_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
# META_API_VERSION=v22.0
# META_PIXEL_ID=
# META_TEST_EVENT_CODE=

# --- Snap ---
SNAP_CLIENT_ID=
SNAP_CLIENT_SECRET=
SNAP_REFRESH_TOKEN=
SNAP_AD_ACCOUNT_ID=
# SNAP_PIXEL_ID=

# --- TikTok (Promopult SDK) ---
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_REFRESH_TOKEN=
TIKTOK_ADVERTISER_ID=
# TIKTOK_PIXEL_CODE=

# --- Sync (all platforms) ---
ADS_INSIGHTS_LOOKBACK_DAYS=30
# ADS_CAMPAIGN_SYNC_HOURS=6
# ADS_OUTCOME_INTERVAL=60
