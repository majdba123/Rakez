{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "anthropic-ai/sdk": "^0.9.0",
        "barryvdh/laravel-dompdf": "*",
        "carlos-meneses/laravel-mpdf": "^2.1",
        "facebook/php-business-sdk": "22.0",
        "filament/filament": "5.4",
        "laravel/framework": "^12.0",
        "laravel/reverb": "^1.6",
        "laravel/sanctum": "^4.2",
        "laravel/tinker": "^2.10.1",
        "maatwebsite/excel": "^3.1.63",
        "mpdf/mpdf": "^8.2",
        "openai-php/laravel": "^0.18.0",
        "promopult/tiktok-marketing-api": "3.1",
        "smalot/pdfparser": "^2.0",
        "spatie/laravel-permission": "^6.24",
        "twilio/sdk": "^7.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.24",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpunit/phpunit": "^11.5.3"
    },
    "autoload": {
        "files": [
            "app/Support/helpers.php"
        ],
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "composer install",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install",
            "npm run build"
        ],
        "assets:publish": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan filament:assets --ansi"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "test:e2e-ai": [
            "@php artisan config:clear --ansi",
            "@php artisan test --group=ai-e2e-real"
        ],
        "test:e2e-ai-arabic-roles": [
            "@php artisan config:clear --ansi",
            "@php artisan test tests/Integration/AI/AIArabicRolesRealE2ETest.php"
        ],
        "test:ai-qa-quality": [
            "@php artisan config:clear --ansi",
            "@php artisan test tests/Integration/AI/AiRealQaQualityE2ETest.php"
        ],
        "test:ai-qa-suite": [
            "@php artisan config:clear --ansi",
            "@php artisan test tests/Feature/AI/AiApiUnauthenticatedTest.php tests/Feature/AI/AiToolsPermissionTest.php tests/Feature/AI/AiBootstrapRoleToolGateParityTest.php tests/Feature/AI/AiScenarioMatrixFeatureTest.php tests/Integration/AI/AiRealQaQualityE2ETest.php"
        ],
        "test:ai-hard-proof-live": [
            "Composer\\Config::disableProcessTimeout",
            "@php tests/Support/EnforceAiHardProofLive.php",
            "@php artisan config:clear --ansi",
            "@php artisan test tests/Integration/AI/AiRealQaHardProofToolsDecisionTest.php tests/Integration/AI/AiRealQaStreamParityTest.php tests/Integration/AI/AiRealQaToolFailureResilienceTest.php tests/Integration/AI/AiRealQaRetrievalHardCasesTest.php tests/Integration/AI/AiRealQaRoleDepthMatrixTest.php"
        ],
        "record:ai-e2e": [
            "@php artisan config:clear --ansi",
            "@php artisan ai:record-e2e-responses"
        ],
        "record:ai-e2e-and-tests": [
            "@php artisan config:clear --ansi",
            "@php artisan ai:record-e2e-responses",
            "@composer run test:e2e-ai"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-install-cmd": [
            "@composer run assets:publish"
        ],
        "post-update-cmd": [
            "@composer run assets:publish"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "audit": {
            "block-insecure": false
        },
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
