			"name": "Auth",
			"item": [
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"  var j = pm.response.json();",
									"  var t = j.access_token || j.token;",
									"  if (t) pm.collectionVariables.set('token', t);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [ { "key": "Accept", "value": "application/json" } ],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"sales.leader@rakez.com\",\n  \"password\": \"password\"\n}"
						},
						"url": "{{base_url}}/login",
						"description": "Use sales/marketing user email. Seeded: sales.leader@rakez.com, ahmed@rakez.com.",
						"auth": { "type": "noauth" }
					},
					"response": []
				}
			]
		},
