						"url": {
							"raw": "{{base_url}}/project_management/teams/import_csv",
							"host": ["{{base_url}}"],
							"path": ["project_management", "teams", "import_csv"]
						},
						"description": "Upload a CSV file to bulk-import teams.\n\nRequired columns: name\nOptional columns: code, description\n\nTeam names must be unique. If code is omitted, it is auto-generated (T000001 pattern).\n\nSample file: doc_of_csv/teams.csv"
					}
