      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Empty assignee_marketer_id makes raw JSON invalid (\"marketer_id\": ,) and all fields look \"missing\" to Laravel.",
              "var a = pm.collectionVariables.get('assignee_marketer_id');",
              "var m = pm.collectionVariables.get('marketer_id');",
              "if (!a || String(a).trim() === '') {",
              "  var fallback = (m && String(m).trim() !== '') ? String(m) : '1';",
              "  pm.collectionVariables.set('assignee_marketer_id', fallback);",
              "}"
            ],
            "id": "e59d0b2d-5f11-4229-a090-e8d70d6f5fe3"
          }
        }
