              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test(\"Create single-unit: 201 or 4xx validation\", function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([201, 400, 422]);",
                  "  pm.expect(pm.response.code).to.not.equal(401);",
                  "});",
                  "if (pm.response.code === 201) {",
                  "  pm.test(\"Create target returns success\", function () { pm.expect(json.success).to.eql(true); });",
                  "}",
                  "const createdTargetId = (json.data && (json.data.target_id || json.data.id)) || null;",
                  "if (createdTargetId) {",
                  "  pm.collectionVariables.set(\"target_id\", String(createdTargetId));",
                  "}"
