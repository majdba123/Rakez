        {
          "name": "Get Team Projects",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Team projects returns 200\", function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.test(\"Team projects JSON shape\", function () {",
                  "  pm.expect(json).to.have.property(\"success\", true);",
                  "  pm.expect(json.data).to.be.an(\"array\");",
                  "  pm.expect(json.meta).to.have.property(\"pagination\");",
                  "});",
                  "const strict = pm.collectionVariables.get(\"strict_seed_assertions\") !== \"false\";",
                  "if (strict) {",
                  "  pm.test(\"At least one team project (seed: SalesLeaderTeamProjectsLinkSeeder + completed contracts)\", function () {",
                  "    const total = (json.meta && json.meta.pagination && json.meta.pagination.total) || 0;",
                  "    pm.expect(total, \"Empty: run php artisan db:seed --class=SalesLeaderTeamProjectsLinkSeeder\").to.be.at.least(1);",
                  "  });",
                  "}",
                  "if (json.data && json.data.length && json.data[0].contract_id) {",
                  "  pm.collectionVariables.set(\"contract_id\", String(json.data[0].contract_id));",
                  "}"
                ],
                "id": "39ea6572-e774-46b7-adb0-3011f17ee357"
