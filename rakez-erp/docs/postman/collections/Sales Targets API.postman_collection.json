          "name": "Login - Sales Leader",
          "event": [
            {
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test(\"Leader login is accepted\", function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 429]);",
                  "});",
                  "if (json.access_token) {",
                  "  pm.collectionVariables.set(\"leader_token\", json.access_token);",
                  "  pm.collectionVariables.set(\"active_token\", json.access_token);",
                  "}",
                  "if (json.user && json.user.id) {",
                  "  pm.collectionVariables.set(\"leader_user_id\", String(json.user.id));",
                  "}"
                ],
                "type": "text/javascript",
                "id": "04019faa-7b8a-4bf1-a119-7a9fcf539ed8"
